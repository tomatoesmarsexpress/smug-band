---
import Layout from '../layouts/Layout.astro';
import teamImg from '../assets/images/team.png';
import fynnCariImg from '../assets/images/fynn_cari.png';
---

<Layout>
	<main class="min-h-screen flex flex-col items-center px-6 pt-24 pb-16">
		<img
			src={teamImg.src}
			width={teamImg.width}
			height={teamImg.height}
			alt="Über uns"
			class="w-full max-w-[10rem] md:max-w-[13rem] mb-4"
			loading="lazy"
			decoding="async"
		/>

		<img
			src={fynnCariImg.src}
			width={fynnCariImg.width}
			height={fynnCariImg.height}
			alt="Fynn & Cari"
			class="mt-6 w-full max-w-[20rem] sm:max-w-[28rem] md:max-w-3xl rounded-lg"
			loading="lazy"
			decoding="async"
		/>

		<p class="mt-2 text-slate-700 text-center">Erfahre mehr über uns auf insta :D</p>
	</main>
</Layout>
