---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
// 1. Die Image-Komponente importieren
import { Image } from 'astro:assets';

// 2. Alle Bilder explizit importieren
import logoImg from '../assets/images/smuglogo.webp';
import fynnImg from '../assets/images/fynnimage.png';
import xbarImg from '../assets/images/xbarbild.png';
import jakeImg from '../assets/images/jakesax.png';
import gruppenImg from '../assets/images/gruppenbild.png';

const epkPhotos = [
  { src: fynnImg, alt: "EPK Foto 1" },
  { src: xbarImg, alt: "EPK Foto 2" },
  { src: jakeImg, alt: "EPK Foto 3" },
  { src: gruppenImg, alt: "EPK Foto 4" },
];

const musicVideos = [
  { src: "https://www.youtube-nocookie.com/embed/uPR02K2Q7Us", title: "Curves" },
  { src: "https://www.youtube-nocookie.com/embed/E9c_FGkbVc0", title: "KTP" },
  { src: "https://www.youtube-nocookie.com/embed/asJbd2Nx6Nk", title: "Winter Demo" },
];
---

<Layout>
  <main class="mx-auto w-full max-w-6xl px-4 pb-16 pt-24 sm:px-8 page-fade-in">

    <header class="mb-10">
      <div class="flex justify-center mb-6">
        <a href="/" aria-label="Zur Startseite">
          <Image
            src={logoImg}
            alt="Band Logo"
            width={900}
            height={320}
            class="h-auto w-auto max-w-[16rem] object-contain sm:max-w-[18rem]"
          />
        </a>
      </div>

      <div class="inline-flex items-center gap-3 rough-box px-4 py-3">
        <span class="text-3xl font-black uppercase tracking-[0.08em]">EPK</span>
        <span class="text-sm font-semibold sm:text-base">Electronic Press Kit</span>
      </div>
    </header>

    <section class="space-y-8">

      <div class="rounded-lg border-2 border-black/80 bg-white/60 p-5 shadow-sm">
        <h2 class="text-2xl font-black uppercase tracking-[0.06em] sm:text-3xl">about</h2>
        <p class="mt-3 text-sm leading-relaxed sm:text-base">
          Wir sind Smug (ehemals cacbratzen), eine energetische Punk-Band mit Blues-Einflüssen. Seit 2023 mischen wir mit unserem eigenen Sound die Münchner Musikszene auf. Gespielt haben wir schon über 20 Shows, unter anderem auch im Strom. Ob kleine Bar im Keller oder große Stage, mit unseren Songs fetzen wir jede Location.
          <br><br>
          "Ich glaub ehrlich das war das beste Konzert auf dem ich war..." - Konzertbesucher von Smug, 2025 
        </p>
      </div>

      <div class="rounded-lg border-2 border-black/80 bg-white/60 p-5">
        <h2 class="text-2xl font-black uppercase tracking-[0.06em] sm:text-3xl">Pics</h2> 
        <div class="relative mt-4">

          <button type="button" id="scrollLeft" class="absolute left-0 top-1/2 z-10 -translate-y-1/2 rounded-full border-2 border-black/80 bg-white/80 px-3 py-2 text-black shadow-sm hover:bg-white">←</button>
          <button type="button" id="scrollRight" class="absolute right-0 top-1/2 z-10 -translate-y-1/2 rounded-full border-2 border-black/80 bg-white/80 px-3 py-2 text-black shadow-sm hover:bg-white">→</button>

          <div id="photoScroller" class="overflow-x-auto pb-2 pt-1 [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
            <div class="flex gap-4 pr-10">
              {epkPhotos.map((photo) => (
                <figure class="w-[70vw] max-w-[340px] flex-none rounded-lg bg-black/5 p-2 shadow-sm">
                  <div class="relative aspect-[4/3] w-full overflow-hidden rounded-md">
                    <Image
                      src={photo.src}
                      alt={photo.alt}
                      class="h-full w-full object-contain"
                    />
                  </div>
                </figure>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-lg border-2 border-black/80 bg-white/60 p-5">
        <h2 class="text-2xl font-black uppercase tracking-[0.06em] sm:text-3xl">Musik Videos</h2>
        <div class="mt-4 grid grid-cols-1 gap-6 md:grid-cols-3">
          {musicVideos.map((v) => (
            <div class="w-full">
              <div class="relative w-full pt-[56.25%]">
                <iframe
                  class="absolute inset-0 h-full w-full rounded-lg"
                  src={v.src}
                  title={v.title}
                  loading="lazy"
                  allowfullscreen
                ></iframe>
              </div>
              <p class="mt-2 text-center text-sm font-semibold">{v.title}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="rounded-lg border-2 border-black/80 bg-white/60 p-5">
        <h2 class="text-2xl font-black uppercase tracking-[0.06em] sm:text-3xl">Spotify</h2>
        <div class="mt-4">
          <iframe
            class="w-full rounded-xl"
            style="border-radius:12px"
            src="https://open.spotify.com/embed/track/1KfxliYQULuMnVV2WCnuzn?utm_source=generator"
            height="352"
            frameborder="0"
            allowfullscreen
            allow="clipboard-write; fullscreen; picture-in-picture"
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <div class="rounded-lg border-2 border-black/80 bg-white/60 p-5">
        <h2 class="text-2xl font-black uppercase tracking-[0.06em] sm:text-3xl">Kontakt</h2>
        <p class="mt-3 text-sm leading-relaxed sm:text-base">
          Schreib uns gerne eine E-Mail:
        </p>
        <a
          href="mailto:smug.kontakt@gmail.com"
          class="mt-4 inline-block rounded-lg border-2 border-black/80 bg-black px-6 py-2 font-semibold lowercase text-white transition-colors hover:bg-black/90"
        >
          smug.kontakt@gmail.com
        </a>
      </div>

    </section>
  </main>
</Layout>

<script>
  // Scroller Script bleibt gleich...
  const scroller = document.getElementById('photoScroller')!;
  document.getElementById('scrollLeft')!.addEventListener('click', () => {
    scroller.scrollBy({ left: -Math.max(240, scroller.clientWidth * 0.75), behavior: 'smooth' });
  });
  document.getElementById('scrollRight')!.addEventListener('click', () => {
    scroller.scrollBy({ left: Math.max(240, scroller.clientWidth * 0.75), behavior: 'smooth' });
  });
</script>