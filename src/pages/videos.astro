---
import Layout from '../layouts/Layout.astro';
import videosImg from '../assets/images/videos.png';
import ktpThumb from '../assets/images/ktp_frame.png';
import curvesThumb from '../assets/images/curves_demo_frame.png';
import winterThumb from '../assets/images/winter_demo_frame.png';
---

<Layout>
	<main class="min-h-screen flex flex-col items-center px-6 pt-24 pb-16">

		<img
			src={videosImg.src}
			width={videosImg.width}
			height={videosImg.height}
			alt="Videos"
			class="w-full max-w-[12rem] md:max-w-[15rem] mb-6"
			loading="lazy"
			decoding="async"
		/>

		<section class="mt-10 w-full max-w-6xl space-y-10">
			<details class="group w-full">
				<summary class="list-none cursor-pointer">
					<div class="flex flex-col items-center gap-3">
						<h2 class="font-brutal text-2xl md:text-4xl font-semibold text-slate-900">KTP</h2>
						<div class="w-full group-open:hidden max-w-4xl">
							<img
								src={ktpThumb.src}
								width={ktpThumb.width}
								height={ktpThumb.height}
								alt="KTP – Thumbnail"
								class="w-full rounded-lg"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</div>
				</summary>
				<div class="mt-4">
					<div class="relative w-full max-w-4xl mx-auto pt-[56.25%]">
						<iframe
							src="https://www.youtube-nocookie.com/embed/E9c_FGkbVc0"
							title="KTP"
							class="absolute inset-0 w-full h-full rounded-lg"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</details>

			<details class="group w-full">
				<summary class="list-none cursor-pointer">
					<div class="flex flex-col items-center gap-3">
						<h2 class="font-brutal text-2xl md:text-4xl font-semibold text-slate-900">Curves Demo</h2>
						<div class="w-full group-open:hidden max-w-4xl">
							<img
								src={curvesThumb.src}
								width={curvesThumb.width}
								height={curvesThumb.height}
								alt="Curves Demo – Thumbnail"
								class="w-full rounded-lg"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</div>
				</summary>
				<div class="mt-4">
					<div class="relative w-full max-w-4xl mx-auto pt-[56.25%]">
						<iframe
							src="https://www.youtube-nocookie.com/embed/uPR02K2Q7Us"
							title="Curves Demo"
							class="absolute inset-0 w-full h-full rounded-lg"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</details>

			<details class="group w-full">
				<summary class="list-none cursor-pointer">
					<div class="flex flex-col items-center gap-3">
						<h2 class="font-brutal text-2xl md:text-4xl font-semibold text-slate-900">Winter Demo</h2>
						<div class="w-full group-open:hidden max-w-4xl">
							<img
								src={winterThumb.src}
								width={winterThumb.width}
								height={winterThumb.height}
								alt="Winter Demo – Thumbnail"
								class="w-full rounded-lg"
								loading="lazy"
								decoding="async"
							/>
						</div>
					</div>
				</summary>
				<div class="mt-4">
					<div class="relative w-full max-w-4xl mx-auto pt-[56.25%]">
						<iframe
							src="https://www.youtube-nocookie.com/embed/asJbd2Nx6Nk"
							title="Winter Demo"
							class="absolute inset-0 w-full h-full rounded-lg"
							loading="lazy"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
							allowfullscreen
						></iframe>
					</div>
				</div>
			</details>
		</section>
	</main>
</Layout>
